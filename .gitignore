# --- DEPENDENCIES ---
# Bloque les node_modules à la racine et dans n'importe quel sous-dossier
node_modules/
**/node_modules/

# --- SECRETS & CONFIG ---
# Bloque les fichiers d'environnement partout (très important pour tes clés API)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
**/.env
**/.env.local
*/.env
/.env

# --- BUILDS & OUTPUTS ---
# Bloque les dossiers de compilation (React, Vue, etc.)
dist/
build/
.next/
out/

# --- LOGS ---
# Bloque les fichiers de logs qui polluent pour rien
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/
*.log

# --- OS FILES ---
# Fichiers système invisibles (Mac et Windows)
.DS_Store
Thumbs.db

# --- IDE ---
# Fichiers de config de ton éditeur (optionnel mais recommandé)
.vscode/
.idea/
*.swp